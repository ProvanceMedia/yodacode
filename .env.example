# YodaCode — Environment Configuration
# Copy this to .env and fill in your values.
# chmod 600 .env — secrets should not be world-readable.

# ─── Claude Code Auth ─────────────────────────────────────────────────────
# Long-lived OAuth token from your Claude Max subscription.
# Generate via: claude setup-token (on a machine with a browser)
# Valid for 1 year. Do NOT set ANTHROPIC_API_KEY — that would use paid API credits.
CLAUDE_CODE_OAUTH_TOKEN=

# ─── Slack ────────────────────────────────────────────────────────────────
# Create a Slack app from the manifest at scripts/slack-app-manifest.yaml
# then copy these from the app config page.
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=
SLACK_TEST_CHANNEL_ID=

# ─── Surfaces ─────────────────────────────────────────────────────────────
# Comma-separated list of enabled surfaces. Options: slack, whatsapp
YODA_SURFACES=slack

# ─── Reply Policy ─────────────────────────────────────────────────────────
# Slack user IDs the bot replies to in DMs (comma-separated)
YODA_DM_AUTHORIZED_USERS=
# Channel IDs where the bot replies on @-mention (comma-separated)
YODA_MENTION_CHANNELS=
# Restricted channels: channel:user pairs — only respond when that user mentions you
YODA_RESTRICTED_CHANNELS=
# User IDs authorised to send "stop" commands (comma-separated)
YODA_STOP_AUTHORIZED_USERS=

# ─── Model Config ─────────────────────────────────────────────────────────
# Primary model (leave empty for Claude Code default = claude-sonnet-4-6)
YODA_CLAUDE_MODEL=
# Fallback models tried when primary returns 529 (comma-separated)
YODA_CLAUDE_FALLBACK_MODELS=claude-haiku-4-5
# Max API retries before failing fast (default 3)
YODA_CLAUDE_MAX_RETRIES=3
# Hard timeout per claude invocation in ms (default 600000 = 10 min)
YODA_CLAUDE_TIMEOUT_MS=600000
# Reasoning effort: low | medium | high | xhigh | max. Empty = the model's
# default (high on Opus 4.7/4.8 and Sonnet 4.6). Higher = deeper reasoning, more
# quota per turn. No effect on Haiku; xhigh is Opus 4.7/4.8 only (others clamp to high).
YODA_CLAUDE_EFFORT=
# Advanced: thread-sticky escalation triggers. Say one of these in a thread to
# run it at xhigh effort (sticky); the "off" form (e.g. "xhigh off") stops it.
# Defaults shown — uncomment to override.
# YODA_EFFORT_ESCALATE_PATTERN=\b(xhigh|ultrathink)\b
# YODA_EFFORT_DEESCALATE_PATTERN=\b(?:xhigh|ultrathink|effort)\s+(?:off|stop|normal)\b|\bnormal\s+effort\b

# Persistent thread sessions (default on). Each thread resumes its own agent
# session across replies — prior turns and tool results carry over, and only
# new messages are sent per tick. Set 0 for fully-stateless replies.
# YODA_SESSION_RESUME=1
# Threads idle longer than this start a fresh session (ms, default 14 days).
# YODA_SESSION_MAX_AGE_MS=1209600000
# Rotate to a fresh session once one reply's total input (fresh + cached)
# reaches this many tokens — bounds per-reply cost on long-lived threads.
# 0 disables rotation.
# YODA_SESSION_ROTATE_TOKENS=120000

# ─── Update notifications ─────────────────────────────────────────────────
# Once a day the bot checks for a newer release; when one appears it DMs you
# once, and the yodacode CLI shows a one-line banner. Set 0 to disable both.
# YODA_UPDATE_CHECK=1
# Forks: point the check at your own GitHub repo (owner/name).
# YODA_UPDATE_REPO=ProvanceMedia/yodacode
# Allowed tools for agent runs
YODA_ALLOWED_TOOLS=Bash,Read,Write,Edit,WebFetch,Glob,Grep,Task

# ─── WhatsApp (optional — only if 'whatsapp' is in YODA_SURFACES) ────────
# Phone number in international format, no '+' (e.g. 44XXXXXXXXXX)
YODA_WHATSAPP_AUTHORIZED=
YODA_WHATSAPP_PAIRING_PHONE=
# Group JIDs to respond in (comma-separated, default: ignore all groups)
YODA_WHATSAPP_GROUPS=

# ─── Web Dashboard (optional) ────────────────────────────────────────────
YODA_UI_PORT=7890
YODA_UI_USER=yoda
YODA_UI_PASS=

# ─── Your API Keys ───────────────────────────────────────────────────────
# Add your own service keys below. These are read by refresh-capabilities.py
# to auto-generate CAPABILITIES.md. The agent uses them via curl.
#
# Examples:
# HUBSPOT_ACCESS_TOKEN=
# STRIPE_SECRET_KEY=
# GITHUB_PAT=
# OPENAI_API_KEY=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# BRAVE_SEARCH_API_KEY=

# ─── Sandbox ──────────────────────────────────────────────────────────────
# In the default container deployment the container itself is the isolation
# boundary (unprivileged user, no host access, keys held by the broker), so
# leave this off. The bubblewrap option below only applies to a bare-metal
# host install. 'off' (default) / 'auto' (bubblewrap, Linux host installs only).
YODA_SANDBOX=off

# ─── Tool-loop guardrails ────────────────────────────────────────────────
# Wraps every agent run with tool-call tracking. Detects repeat
# failures, no-progress loops, and runaway iteration counts. iteration_cap
# kills the run; warnings just surface in the placeholder.
YODA_MAX_ITERATIONS_SLACK=60
YODA_GUARDRAIL_ENABLED=1
YODA_GUARDRAIL_REPEAT_THRESHOLD=2
YODA_GUARDRAIL_NOPROGRESS_THRESHOLD=3

# ─── Skill self-generation (opt-in) ──────────────────────────────────────
# After ticks ≥30s OR ≥5 tool calls, fire a background agent run that
# decides whether to write workspace/skills/<slug>.md. Closed-loop self-
# improvement — costs one extra haiku call per long conversation.
YODA_SKILL_REFLECTOR_ENABLED=0
# YODA_SKILL_MIN_DURATION_MS=30000
# YODA_SKILL_MIN_TOOL_COUNT=5
# YODA_SKILL_REFLECTOR_MODEL=claude-haiku-4-5
# Per-reflection budget for surface ticks (ms, default 120000). Cron-triggered
# reflections get their own, more generous budget: YODA_CRON_REFLECTOR_TIMEOUT_MS
# (default 600000, 0 = unbounded) applies to both reflector kinds after crons.
# YODA_SKILL_REFLECTOR_TIMEOUT_MS=120000
# YODA_CRON_REFLECTOR_TIMEOUT_MS=600000

# ─── Memory self-generation (opt-in) ─────────────────────────────────────
# Mirror of the skill reflector but for durable FACTS (user-fact, feedback,
# project-state, reference). Appends to MEMORY.md or writes memory/<slug>.md.
YODA_MEMORY_REFLECTOR_ENABLED=0
# YODA_MEMORY_MIN_DURATION_MS=30000
# YODA_MEMORY_MIN_TOOL_COUNT=5
# YODA_MEMORY_REFLECTOR_MODEL=claude-haiku-4-5

# ─── Credential isolation (broker) ───────────────────────────────────────
# YodaCode runs de-rooted by default (docker compose). The service API keys
# above live ONLY in the broker container; the agent container never sees them
# and reaches services through the broker. Nothing to toggle. See docs/BROKER.md.
#
# PUID/PGID: set to your host user (run `id`) so files the agent writes into the
# bind-mounted workspace (memory, state, cron edits) stay owned by you.
PUID=1000
PGID=1000
# TZ: timezone for cron schedules + timestamps.
TZ=UTC
#
# Bare-metal (non-Docker host install) only: scripts/setup-broker.sh sets this.
# YODA_DEROOT=0
