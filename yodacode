#!/usr/bin/env bash
# yodacode — day-to-day CLI for a Docker-installed YodaCode.
#
#   yodacode help     # the full command list
#   yodacode doctor   # diagnose setup & health
#   yodacode update   # pull the latest version and rebuild
#
# Installed on PATH as ~/.local/bin/yodacode by quickstart.sh; also runnable as
# ./yodacode from the repo.
set -uo pipefail
cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
source scripts/common.sh

# ── small helpers ────────────────────────────────────────────────────────────
is_configured() {
  [[ -f .env ]] && grep -q '^CLAUDE_CODE_OAUTH_TOKEN=sk-ant-' .env 2>/dev/null \
                && grep -q '^SLACK_BOT_TOKEN=xoxb-' .env 2>/dev/null
}
version_string() {
  local v t
  v="$(grep -m1 '"version"' package.json 2>/dev/null | sed -E 's/.*"version" *: *"([^"]+)".*/\1/')"
  t="$(git describe --tags 2>/dev/null || true)"   # e.g. v1.4.2-3-gabc123 when ahead of the tag
  # Only append the git description when it adds info beyond the package version.
  [[ -n "$t" && "$t" != "v${v}" ]] && echo "v${v:-?} ($t)" || echo "v${v:-?}"
}
agent_running() { docker compose ps --status running --services 2>/dev/null | grep -qx agent; }
restart_if_running() {
  agent_running || { note "Not running — changes apply next start (yodacode start)."; return 0; }
  # Recreate (not `compose restart`) so config changes the caller just made
  # actually reach the container's environment.
  if spin "Restarting…" "$(mktemp)" docker compose up -d --force-recreate; then ok "Restarted."; else warn "Restart failed — try: yodacode restart"; fi
}

# ── commands ─────────────────────────────────────────────────────────────────
cmd_help() {
  cat <<EOF

$(echo -e "${C}${B}yodacode${X}") — your own Claude, on your server

$(echo -e "${B}Setup${X}")
  yodacode              run the guided installer (or show status if set up)
  yodacode doctor       diagnose setup & health, with fixes
  yodacode update       pull the latest version and rebuild

$(echo -e "${B}Run${X}")
  yodacode start        start the bot
  yodacode stop         stop it
  yodacode restart      apply .env changes
  yodacode logs         follow the agent logs
  yodacode shell        open a shell in the agent container

$(echo -e "${B}Configure${X}")
  yodacode slack        (re)connect the Slack app + tokens
  yodacode googlechat   connect Google Chat (guided; needs Google Workspace)
  yodacode commitments  set up the daily digest of promises made + follow-up drafts
  yodacode persona      change bot name, your name, timezone
  yodacode model [name] show / set the Claude model
  yodacode tools        toggle reflectors & guardrails
  yodacode addkey       give the bot an API key (via the broker)
  yodacode connect      sign the bot into an OAuth service (Gmail etc.)
  yodacode install-browsers  give the bot a headless browser (one-time ~300MB)

$(echo -e "${B}Info${X}")
  yodacode status       what's configured + container state
  yodacode version      installed version
  yodacode help         this list

EOF
}

cmd_doctor() {
  title "yodacode doctor"
  local problems=0 ps bt at tmp resp rc
  check_key() {  # name expected-prefix fix-hint
    local v; v="$(env_get "$1")"
    if [[ -n "$v" && "$v" == "$2"* ]]; then ok "$1 set"
    elif [[ -n "$v" ]]; then warn "$1 set but doesn't start with $2 — likely wrong"; problems=$((problems+1))
    else fail "$1 missing"; note "   fix: $3"; problems=$((problems+1)); fi
  }

  # Docker
  if command -v docker >/dev/null 2>&1; then
    if docker info >/dev/null 2>&1; then ok "Docker daemon running"
    else fail "Docker installed but the daemon isn't running"; note "   fix: sudo systemctl start docker"; problems=$((problems+1)); fi
  else fail "Docker not installed"; note "   fix: ./quickstart.sh installs it"; problems=$((problems+1)); fi

  # Compose + image
  [[ -f compose.yaml || -f docker-compose.yml ]] && ok "compose file present" || { fail "no compose.yaml in $PWD"; problems=$((problems+1)); }
  if docker image inspect yodacode:local >/dev/null 2>&1; then ok "Image built (yodacode:local)"
  else warn "Image not built yet — run: yodacode update"; fi

  # .env keys
  if [[ -f .env ]]; then
    ok ".env present"
    check_key CLAUDE_CODE_OAUTH_TOKEN sk-ant- "re-run sign-in via ./quickstart.sh"
    check_key SLACK_BOT_TOKEN xoxb- "yodacode slack"
    check_key SLACK_APP_TOKEN xapp- "yodacode slack"
    if [[ -n "$(env_get YODA_DM_AUTHORIZED_USERS)" ]]; then ok "Your Slack member ID set"
    else fail "YODA_DM_AUTHORIZED_USERS missing — the bot won't reply to anyone"; note "   fix: yodacode slack"; problems=$((problems+1)); fi
  else fail ".env missing"; note "   fix: ./quickstart.sh"; problems=$((problems+1)); fi

  # Version — live check against the repo's release tags (short timeout).
  local cur latest
  cur="v$(grep -m1 '"version"' package.json 2>/dev/null | sed -E 's/.*"([0-9]+\.[0-9]+\.[0-9]+)".*/\1/')"
  latest="$(timeout 8 git ls-remote --tags origin 'v*' 2>/dev/null | sed 's#.*refs/tags/##' \
            | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | sort -V | tail -1)"
  if [[ -z "$latest" ]]; then note "   (couldn't check for updates — offline?)"
  elif [[ "$latest" == "$cur" ]]; then ok "Up to date ($cur)"
  elif [[ "$(printf '%s\n%s\n' "$cur" "$latest" | sort -V | tail -1)" == "$latest" ]]; then
    warn "Update available: $latest (installed $cur)"; note "   fix: yodacode update"
  else ok "Running $cur (ahead of the latest tag $latest)"; fi

  # Memory / OOM — the #1 failure mode on tiny VMs: the kernel SIGKILLs the
  # Claude engine mid-reply and the bot silently fails.
  local mem_mb swap_mb
  mem_mb="$(awk '/^MemTotal/{print int($2/1024)}' /proc/meminfo 2>/dev/null || echo 0)"
  swap_mb="$(awk '/^SwapTotal/{print int($2/1024)}' /proc/meminfo 2>/dev/null || echo 0)"
  if (( mem_mb + swap_mb >= 1792 )); then ok "Memory headroom (${mem_mb}MB RAM + ${swap_mb}MB swap)"
  else
    fail "Low memory: ${mem_mb}MB RAM + ${swap_mb}MB swap — replies get OOM-killed"
    note "   fix: resize to ≥1GB RAM, or add swap: fallocate -l 2G /swapfile && chmod 600 /swapfile && mkswap /swapfile && swapon /swapfile"
    problems=$((problems+1))
  fi
  # Informational (not counted as a problem): the kernel log persists since
  # boot, so an old unrelated kill shouldn't fail an otherwise healthy setup.
  if dmesg 2>/dev/null | grep -qiE 'out of memory|oom-kill'; then
    warn "Kernel OOM kills found in dmesg — if replies fail with SIGKILL, this is why (add RAM/swap)"
  fi

  # Containers
  ps="$(docker compose ps --status running --services 2>/dev/null || true)"
  if grep -qx agent <<<"$ps"; then ok "agent container running"
  else warn "agent container not running — start: yodacode start"; fi
  grep -qx broker <<<"$ps" && ok "broker container running" || note "   (broker starts on demand — fine if idle)"

  # Slack tokens live — but a network blip must not look like a bad token.
  bt="$(env_get SLACK_BOT_TOKEN)"; at="$(env_get SLACK_APP_TOKEN)"
  if [[ "$bt" == xoxb-* ]] && command -v curl >/dev/null 2>&1; then
    rc=0; resp="$(curl -sS --connect-timeout 5 --max-time 10 -H "Authorization: Bearer $bt" https://slack.com/api/auth.test 2>/dev/null)" || rc=$?
    if [[ $rc -ne 0 || -z "$resp" ]]; then warn "Couldn't reach Slack to verify the bot token (offline?) — skipping"
    elif grep -q '"ok":true' <<<"$resp"; then ok "Slack bot token accepted by Slack"
    else fail "Slack bot token rejected by Slack"; note "   fix: yodacode slack"; problems=$((problems+1)); fi
  fi
  if [[ "$at" == xapp-* ]] && command -v curl >/dev/null 2>&1; then
    rc=0; resp="$(curl -sS --connect-timeout 5 --max-time 10 -X POST -H "Authorization: Bearer $at" https://slack.com/api/apps.connections.open 2>/dev/null)" || rc=$?
    if [[ $rc -ne 0 || -z "$resp" ]]; then warn "Couldn't reach Slack to verify the app token (offline?) — skipping"
    elif grep -q '"ok":true' <<<"$resp"; then ok "Slack app token accepted (connections:write)"
    else fail "Slack app token rejected — missing connections:write?"; note "   fix: yodacode slack"; problems=$((problems+1)); fi
  fi

  # Google Chat (Pub/Sub pull) — live check: mint a token from the SA key and
  # prove the subscription is reachable. Catches the add-on-box / IAM / wrong-
  # subscription failures that otherwise only surface in the logs after the fact.
  if [[ -n "$(env_get GOOGLE_CHAT_SA_KEY)" || "$(env_get YODA_SURFACES)" == *googlechat* ]]; then
    if [[ -z "$(env_get GOOGLE_CHAT_SA_KEY)" ]]; then
      fail "Google Chat: GOOGLE_CHAT_SA_KEY missing"; note "   fix: yodacode googlechat"; problems=$((problems+1))
    elif [[ -z "$(env_get GOOGLE_CHAT_SUBSCRIPTION)" ]]; then
      fail "Google Chat: GOOGLE_CHAT_SUBSCRIPTION missing"; note "   fix: yodacode googlechat"; problems=$((problems+1))
    elif ! grep -qx agent <<<"$ps"; then
      note "Google Chat configured — live check skipped (agent not running)"
    else
      tmp="$(mktemp)"
      # </dev/null: compose exec keeps stdin attached (-T only drops the TTY).
      if docker compose exec -T --workdir /app/workspace agent node lib/googlechat-doctor.js </dev/null >"$tmp" 2>&1; then
        ok "Google Chat: Pub/Sub subscription reachable"
      else
        fail "Google Chat: $(tail -1 "$tmp" | head -c 180)"
        note "   Likely: the 'Build this Chat app as a Workspace add-on' box is still ticked (untick it — it silently breaks Pub/Sub),"
        note "   the topic isn't granted Publisher for chat-api-push@system.gserviceaccount.com, or GOOGLE_CHAT_SUBSCRIPTION is wrong."
        note "   fix: yodacode googlechat"
        problems=$((problems+1))
      fi
      rm -f "$tmp"
    fi
  fi

  # OAuth sign-ins (Google etc.) — one live token mint per connected provider,
  # through the broker, so a dead refresh token is caught here and not mid-chat.
  if [[ -s workspace/broker/oauth-grants.json ]] && command -v python3 >/dev/null 2>&1; then
    while IFS=$'\t' read -r oslug olabel ohost opath oacct ominted opub; do
      [[ -z "$oslug" ]] && continue
      if ! grep -qx agent <<<"$ps"; then
        note "$olabel connected${oacct:+ ($oacct)} — live check skipped (agent not running)"
        continue
      fi
      if [[ -z "$ohost" || -z "$opath" ]]; then
        note "$olabel connected${oacct:+ ($oacct)} — no cheap test endpoint; verified at connect time"
        continue
      fi
      tj="$(python3 -c 'import json,sys; print(json.dumps({"host": sys.argv[1], "path": sys.argv[2], "method": "GET"}))' "$ohost" "$opath")"
      tmp="$(mktemp)"
      # </dev/null: compose exec keeps stdin attached (-T only drops the TTY)
      # and would drain the doctor-plan lines feeding this loop.
      if docker compose exec -T agent broker call http_call "$tj" </dev/null >"$tmp" 2>&1; then
        ok "$olabel sign-in works${oacct:+ ($oacct)}"
      else
        problems=$((problems+1))
        if grep -q "expired or been revoked" "$tmp"; then
          fail "$olabel sign-in has expired or been revoked${oacct:+ ($oacct)}"
          # Google's classic cause: a consent screen left in "Testing" kills
          # refresh tokens after 7 days. We recorded the publish answer at
          # connect time. The Testing diagnosis is Google-only — other
          # providers have no such state and get their own likely causes.
          if [[ "$opub" == 0 ]]; then
            note "   likely cause: the consent screen is still in 'Testing' (you said it wasn't published)."
            note "   fix: publish the app to 'In production', then: yodacode connect $oslug --renew"
          elif [[ "$oslug" == google ]] && (( ${ominted:-0} > 0 && $(date +%s) - ominted < 777600 )); then
            note "   it died within ~9 days of sign-in — the consent screen may be in 'Testing'. Publish it,"
            note "   then: yodacode connect $oslug --renew"
          elif [[ "$oslug" == microsoft ]]; then
            note "   likely: 90+ days without use, a password change/admin reset, or an org"
            note "   Conditional Access policy. fix: yodacode connect microsoft --renew"
          else
            note "   fix: yodacode connect $oslug --renew   (password changes and revocation also cause this)"
          fi
        else
          fail "$olabel test call failed:"
          tail -c 200 "$tmp" 2>/dev/null | tr -d '\0' | sed 's/^/    /'
          note "   fix: yodacode connect $oslug --renew"
        fi
      fi
      rm -f "$tmp"
    done < <(python3 scripts/connect-lib.py doctor-plan 2>/dev/null)
  fi

  # Claude sign-in (needs the agent up)
  if grep -qx agent <<<"$ps"; then
    tmp="$(mktemp)"
    # Gate on the success envelope's is_error flag, not the reply text — a
    # healthy agent may answer "OK." / "Okay" and vary run to run, and matching
    # the word "ok" would false-positive on error bodies mentioning a "token".
    if spin "Checking Claude sign-in (via the agent)…" "$tmp" docker compose exec -T agent claude -p "say OK" --output-format json \
       && grep -qE '"is_error"[ ]*:[ ]*false' "$tmp"; then ok "Claude sign-in works"
    else fail "Claude sign-in failed — the OAuth token may be expired"; note "   fix: re-run ./quickstart.sh to re-issue a token"; problems=$((problems+1)); fi
    rm -f "$tmp"
    # Slack connectivity
    if docker compose logs --tail 200 agent 2>/dev/null | grep -q '"msg":"slack: ready"'; then ok "Slack connection established"
    else warn "No recent 'slack: ready' in logs — check: yodacode logs"; fi
  else
    note "Skipped Claude + Slack-connection checks (agent not running)."
  fi

  echo ""
  if (( problems == 0 )); then ok "All good — no problems found."; return 0
  else fail "$problems problem(s) found — see the fixes above."; return 1; fi
}

cmd_update() {
  title "Updating yodacode"
  require_docker
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
    fail "This isn't a git checkout, so I can't pull updates."
    note "Re-download the latest from https://github.com/ProvanceMedia/yodacode"; return 1; }
  note "Current: $(version_string)"
  spin "Checking for updates…" "$(mktemp)" git fetch --quiet || { fail "git fetch failed — check your network."; return 1; }

  local up behind
  if ! up="$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null)"; then
    if ! git symbolic-ref -q HEAD >/dev/null 2>&1; then
      fail "You're on a detached HEAD (a checked-out tag/commit), not a branch."
      note "Run: git checkout main   then re-run yodacode update."; return 1
    fi
    if git rev-parse --verify -q origin/main >/dev/null 2>&1; then up="origin/main"
    else fail "No upstream configured and no origin/main to compare against."
         note "Set one: git branch --set-upstream-to=origin/main"; return 1; fi
  fi
  behind="$(git rev-list --count "HEAD..$up" 2>/dev/null || echo 0)"
  if [[ "$behind" == 0 ]]; then ok "Already up to date."; return 0; fi

  echo "  $behind new commit(s):"
  git log --oneline "HEAD..$up" 2>/dev/null | head -15 | sed 's/^/    /'
  echo ""
  local a; a="$(ask 'Pull and rebuild now? [Y/n]' 'Y')"
  [[ "${a,,}" =~ ^n ]] && { note "Skipped."; return 0; }

  # Heal a repo left WEDGED by a past update: a prior stash-pop conflict can leave
  # an unmerged file, which then blocks every future 'git pull' with a cryptic
  # "Pulling is not possible because you have unmerged files". Resolve it the same
  # way a live conflict is (your edits win on the clashing lines), so a stuck box
  # recovers itself instead of needing a manual git rescue.
  if git diff --name-only --diff-filter=U 2>/dev/null | grep -q .; then
    warn "Found unresolved conflicts from a previous update — healing them (your edits win):"
    local healed hrc
    healed="$(merge_favor_operator)"; hrc=$?
    [[ -n "$healed" ]] && printf '%s\n' "$healed" | sed 's/^/    /'
    if [[ $hrc -ne 0 ]]; then
      fail "Some non-persona files are still conflicted and need you:"
      git diff --name-only --diff-filter=U 2>/dev/null | sed 's/^/    /'
      note "Resolve their <<<< / ==== / >>>> markers, run: git add <files>, then re-run yodacode update."; return 1
    fi
    # A stash parked by that earlier failed pop is now fully represented in the tree —
    # drop it BY REF. Never a bare `git stash drop` (that removes stash@{0}, which could
    # be an unrelated stash the operator made while troubleshooting the stuck box).
    local sref; sref="$(git stash list 2>/dev/null | grep -m1 'yodacode update' | sed 's/:.*//')"
    [[ -n "$sref" ]] && git stash drop --quiet "$sref" 2>/dev/null || true
    ok "Healed the leftover conflicts; continuing the update."
  fi

  # Legacy installs kept the agent's service notes in the tracked TOOLS.md, which
  # would block a fast-forward. Rescue them into the gitignored TOOLS.local.md and
  # restore TOOLS.md first, so that one file stays clean.
  ensure_tools_local

  # Any OTHER locally-modified tracked file (a customized AGENTS.md/SOUL.md, a
  # patched broker script, the agent-maintained skills/INDEX.md) is a deliberate
  # edit we must PRESERVE, not discard. Shelve them, fast-forward, then re-apply:
  # git does a 3-way merge, so your changes land on top of the updated files.
  local stashed=""
  if ! git diff --quiet HEAD 2>/dev/null; then
    if git stash push -m "yodacode update $(date +%F)" --quiet 2>/dev/null; then stashed=1; fi
  fi

  if ! git pull --ff-only --quiet; then
    [[ -n "$stashed" ]] && git stash pop --quiet 2>/dev/null || true
    fail "git pull failed — the repo history has diverged (local commits?)."
    note "Check 'git status', reconcile with origin/main, then re-run yodacode update."; return 1; fi

  if [[ -n "$stashed" ]]; then
    if git stash pop --quiet 2>/dev/null; then
      ok "Re-applied your local customizations onto the update."
    else
      # The pop hit a conflict. Auto-resolve operator-owned persona docs in YOUR
      # favour (upstream's non-clashing changes still land); leave anything else for
      # a human. This stops a conflict from wedging the repo against future updates —
      # the failure mode that used to require a manual git rescue.
      local resolved rrc
      resolved="$(merge_favor_operator)"; rrc=$?
      if [[ $rrc -ne 0 ]]; then
        warn "Your local edits conflict with the update in files I won't auto-resolve:"
        git diff --name-only --diff-filter=U 2>/dev/null | sed 's/^/    /'
        note "Resolve their <<<< / ==== / >>>> markers, run: git add <files>, then: docker compose up -d --build"
        note "Your shelved edits are also safe in: git stash show -p"
        return 1
      fi
      # Conflicts resolved — a conflicted pop leaves the stash parked, so drop it now.
      git stash drop --quiet 2>/dev/null || true
      if [[ -n "$resolved" ]]; then
        ok "Re-applied your customizations (kept your version where it clashed with the update):"
        printf '%s\n' "$resolved" | sed 's/^/    /'
      else
        ok "Re-applied your local customizations onto the update."
      fi
    fi
  fi

  # Refresh the framework persona doc from the (now-updated) template so new
  # @-imports (e.g. TOOLS.local.md) take effect. Keeps the operator's name/context;
  # their edits live in IDENTITY/USER/MEMORY, not this generated file.
  local bn un tz
  bn="$(env_get BOT_NAME)"; un="$(env_get USER_NAME)"; tz="$(env_get TZ)"
  [[ -f templates/CLAUDE.md.template ]] && sed \
    -e "s/{{BOT_NAME}}/${bn:-Yoda}/g" -e "s/{{USER_NAME}}/${un:-friend}/g" \
    -e "s|{{TIMEZONE}}|${tz:-UTC}|g" -e "s|{{INSTALL_DIR}}|$PWD|g" -e "s|{{DATE}}|$(date +%F)|g" \
    templates/CLAUDE.md.template > workspace/CLAUDE.md

  local log; log="$(mktemp)"
  if spin "Rebuilding & restarting (may take a few minutes)…" "$log" docker compose up -d --build; then
    ok "Rebuilt and restarted."
  else
    fail "Rebuild failed — last lines:"; tail -8 "$log" 2>/dev/null | sed 's/^/    /'; return 1
  fi
  install_cli_wrapper   # self-heal the wrapper if this update added/moved it
  ok "Updated to $(version_string)."
  # A playwright version bump in the new image expects a different chromium
  # revision than the one in the volume — the capability silently flips to ❌
  # unless the operator is told to refresh it.
  if docker compose exec -T agent sh -c 'ls /home/yoda/.cache/ms-playwright 2>/dev/null | grep -q chromium' 2>/dev/null \
     && ! docker compose exec -T agent sh -c 'cd /app/workspace && gosu yoda node bin/browser-tool.cjs probe' >/dev/null 2>&1; then
    warn "This update changed the browser engine version — re-run: yodacode install-browsers"
  fi
}

cmd_start()   { require_docker; if spin "Starting…" "$(mktemp)" docker compose up -d; then ok "Started. Watch it: yodacode logs"; else fail "Start failed — see: docker compose logs"; return 1; fi; }
cmd_stop()    { require_docker; if docker compose down; then ok "Stopped."; else fail "Stop failed."; return 1; fi; }
# up -d --force-recreate, NOT `compose restart`: restart reuses the container's
# original environment, so .env edits silently never load. Recreating is the only
# way "apply .env changes" is actually true.
cmd_restart() { require_docker; if spin "Restarting…" "$(mktemp)" docker compose up -d --force-recreate; then ok "Restarted (fresh .env applied)."; else fail "Restart failed."; return 1; fi; }
cmd_logs()    { require_docker; exec docker compose logs -f agent; }
cmd_shell()   { require_docker; exec docker compose exec agent bash; }

cmd_slack()   { title "Reconfigure Slack"; if configure_slack; then restart_if_running; else fail "Slack setup didn't complete — nothing saved past the last ✓."; return 1; fi; }
cmd_googlechat() { title "Connect Google Chat"; if configure_googlechat; then restart_if_running; else fail "Google Chat setup didn't finish — nothing saved past the last ✓."; return 1; fi; }
cmd_commitments() { title "Daily commitments sweep"; if configure_commitments; then restart_if_running; else fail "Commitments setup didn't finish — nothing enabled."; return 1; fi; }
cmd_persona() { title "Reconfigure persona"; configure_persona && restart_if_running; }
cmd_addkey()  { exec ./quickstart.sh addkey "$@"; }
cmd_connect() { exec ./quickstart.sh connect "$@"; }

# One-time Chromium download into the agent-home volume (~300MB download,
# ~650MB on disk). The image already carries the Playwright module + system
# libraries; the browser binary lives in the volume so it survives container
# recreation and image updates. Probes and install both run as the agent user
# via the tool itself, so the browser revision always matches the module the
# runtime actually loads.
cmd_install_browsers() {
  require_docker
  title "Installing headless Chromium for the agent"
  docker compose ps --status running agent 2>/dev/null | grep -q agent \
    || { fail "The agent container isn't running — start it first: yodacode start"; return 1; }
  browser_probe() { docker compose exec -T agent sh -c 'cd /app/workspace && gosu yoda node bin/browser-tool.cjs probe' >/dev/null 2>&1; }
  if browser_probe; then
    ok "Browser already installed and working — nothing to do."
    return 0
  fi
  note "Downloading Chromium (~300MB download, ~650MB on disk, one-time — it persists across updates)…"
  if ! docker compose exec -T agent sh -c 'cd /app/workspace && gosu yoda node bin/browser-tool.cjs install'; then
    fail "Chromium download failed — check network/disk, then re-run yodacode install-browsers."
    return 1
  fi
  if browser_probe; then
    ok "Browser installed and verified."
    note "CAPABILITIES.md updates on the next restart — restarting now so the bot knows it can browse."
    restart_if_running
  else
    fail "Install finished but the readiness probe still fails — run 'yodacode shell' and try: node bin/browser-tool.cjs probe"
    return 1
  fi
}

cmd_model() {
  local arg="${1:-}"
  if [[ -z "$arg" ]]; then
    title "Model"
    local cur; cur="$(env_get YODA_CLAUDE_MODEL)"
    if [[ -n "$cur" ]]; then echo "  Primary: $cur"; else echo -e "  Primary: ${D}(default — Claude Code picks)${X}"; fi
    echo ""
    note "Set:   yodacode model <name>   e.g. claude-sonnet-4-6 / claude-opus-4-8 / claude-haiku-4-5"
    note "Reset: yodacode model default"
    return 0
  fi
  local v="$arg"; [[ "$arg" == default ]] && v=""
  set_env YODA_CLAUDE_MODEL "$v"
  [[ -n "$v" ]] && ok "Primary model set to $v" || ok "Primary model reset to default"
  restart_if_running
}

show_toggle() {  # key label desc default_on
  local raw on; raw="$(env_get "$1")"
  if [[ "$4" == 1 ]]; then [[ "$raw" == 0 ]] && on=0 || on=1; else [[ "$raw" == 1 ]] && on=1 || on=0; fi
  if [[ "$on" == 1 ]]; then echo -e "  ${G}✓${X} $(printf '%-18s' "$2") ${D}$3${X}"
  else echo -e "  ${R}✗${X} $(printf '%-18s' "$2") ${D}$3${X}"; fi
}
cmd_tools() {
  local name="${1:-}" state="${2:-}" key
  if [[ -z "$name" ]]; then
    title "Tools"
    show_toggle YODA_SKILL_REFLECTOR_ENABLED  skill-reflector  "Skill self-generation after notable conversations" 0
    show_toggle YODA_MEMORY_REFLECTOR_ENABLED memory-reflector "Memory self-generation after notable conversations" 0
    show_toggle YODA_GUARDRAIL_ENABLED        guardrails       "Repeat-failure / no-progress detection (default on)" 1
    echo ""
    note "Toggle: yodacode tools <name> on|off"
    note "Names:  skill-reflector | memory-reflector | guardrails"
    return 0
  fi
  case "$name" in
    skill-reflector)  key=YODA_SKILL_REFLECTOR_ENABLED ;;
    memory-reflector) key=YODA_MEMORY_REFLECTOR_ENABLED ;;
    guardrails)       key=YODA_GUARDRAIL_ENABLED ;;
    *) fail "Unknown tool: $name"; note "Try: skill-reflector | memory-reflector | guardrails"; return 1 ;;
  esac
  case "$state" in
    on)  set_env "$key" 1; ok "$name → on" ;;
    off) set_env "$key" 0; ok "$name → off" ;;
    *)   fail "Need on|off, got: ${state:-(nothing)}"; return 1 ;;
  esac
  restart_if_running
}

cmd_status() {
  title "yodacode status"
  field() { echo -e "  $(printf '%-16s' "$1") ${2:-${D}(unset)${X}}"; }
  field "Install dir" "$PWD"
  field "Version"     "$(version_string)"
  field "Bot name"    "$(env_get BOT_NAME)"
  field "Your name"   "$(env_get USER_NAME)"
  field "Timezone"    "$(env_get TZ)"
  local auth slack_b slack_a
  [[ "$(env_get CLAUDE_CODE_OAUTH_TOKEN)" == sk-ant-* ]] && auth="✓ set" || auth="✗ missing"
  [[ "$(env_get SLACK_BOT_TOKEN)" == xoxb-* ]] && slack_b="✓ set" || slack_b="✗ missing"
  [[ "$(env_get SLACK_APP_TOKEN)" == xapp-* ]] && slack_a="✓ set" || slack_a="✗ missing"
  field "Auth token"  "$auth"
  field "Slack bot"   "$slack_b"
  field "Slack app"   "$slack_a"
  local ps; ps="$(docker compose ps --status running --services 2>/dev/null | tr '\n' ' ' | sed 's/ *$//')"
  field "Running"     "${ps:-${D}(nothing)${X}}"
}

cmd_version() { echo "yodacode $(version_string)"; }

# Maintainer-only release cutter. Refuses to run outside the canonical repo.
CANONICAL_RELEASE_REPO="${YODACODE_RELEASE_REPO:-ProvanceMedia/yodacode}"
bump_version() {  # version kind → new version
  local v="${1%%-*}" kind="$2" maj min pat
  IFS=. read -r maj min pat <<<"$v"
  case "$kind" in
    major) maj=$((maj+1)); min=0; pat=0 ;;
    minor) min=$((min+1)); pat=0 ;;
    patch) pat=$((pat+1)) ;;
    *) return 1 ;;
  esac
  echo "$maj.$min.$pat"
}
cmd_release() {
  local kind="${1:-}"
  case "$kind" in patch|minor|major) ;; *)
    fail "Usage: yodacode release <patch|minor|major>"
    note "patch — bug fixes / internal refactors"
    note "minor — new feature, backwards-compatible"
    note "major — breaking change"; return 1 ;;
  esac
  # Maintainer gate: only run in the canonical repo. Don't print origin — it
  # may carry an embedded credential.
  local origin; origin="$(git remote get-url origin 2>/dev/null)" || { fail "No origin remote — release is maintainer-only."; return 1; }
  [[ "$origin" == *"$CANONICAL_RELEASE_REPO"* ]] || { fail "yodacode release is a maintainer-only command (wrong origin)."; return 1; }

  title "Releasing yodacode"
  [[ -z "$(git status --porcelain)" ]] || { fail "Working tree is dirty — commit or stash first."; return 1; }
  local branch; branch="$(git rev-parse --abbrev-ref HEAD)"
  [[ "$branch" == main ]] || { fail "Not on main (on $branch). Release from main."; return 1; }
  git fetch --quiet || { fail "git fetch failed."; return 1; }
  local behind; behind="$(git rev-list --count 'HEAD..@{upstream}' 2>/dev/null || echo 0)"
  [[ "$behind" == 0 ]] || { fail "Behind origin/main by $behind commit(s). Pull first."; return 1; }

  local curver newver lasttag range commits
  curver="$(grep -m1 '"version"' package.json | sed -E 's/.*"version" *: *"([^"]+)".*/\1/')"
  newver="$(bump_version "$curver" "$kind")" || { fail "Couldn't parse version $curver"; return 1; }
  lasttag="$(git describe --tags --abbrev=0 2>/dev/null || true)"
  range="${lasttag:+$lasttag..}HEAD"
  commits="$(git log --no-merges --format='%s' $range | grep -vE '^Release v[0-9]' || true)"
  [[ -n "$commits" ]] || { fail "No commits since ${lasttag:-repo start} — nothing to release."; return 0; }

  echo "  $curver → $newver  ($kind)"
  echo "  commits since ${lasttag:-repo start}:"
  echo "$commits" | sed 's/^/    • /'
  echo ""
  local ans; ans="$(ask "Cut release v$newver? [y/N]" 'n')"
  [[ "${ans,,}" == y ]] || { note "Aborted."; return 0; }

  local tmpf entryfile ln today
  tmpf="$(mktemp)"; entryfile="$(mktemp)"; today="$(date +%F)"
  # Bump package.json (single root "version").
  sed -E "s/(\"version\"[[:space:]]*:[[:space:]]*\")[^\"]+\"/\1$newver\"/" package.json > "$tmpf" && mv "$tmpf" package.json
  ok "Bumped package.json → $newver"
  # Prepend a CHANGELOG entry before the first existing "## " heading.
  { printf '## v%s — %s\n\n' "$newver" "$today"; echo "$commits" | sed 's/^/- /'; printf '\n'; } > "$entryfile"
  ln="$(grep -n '^## ' CHANGELOG.md | head -1 | cut -d: -f1)"
  if [[ -n "$ln" ]]; then
    { head -n $((ln-1)) CHANGELOG.md; cat "$entryfile"; tail -n +"$ln" CHANGELOG.md; } > "$tmpf" && mv "$tmpf" CHANGELOG.md
  else
    { cat CHANGELOG.md; printf '\n'; cat "$entryfile"; } > "$tmpf" && mv "$tmpf" CHANGELOG.md
  fi
  rm -f "$entryfile"
  ok "Updated CHANGELOG.md"

  git add package.json CHANGELOG.md
  git commit -q -m "Release v$newver"
  git tag -a "v$newver" -m "v$newver"
  ok "Committed and tagged v$newver"

  local push; push="$(ask 'Push to origin now? [Y/n]' 'Y')"
  [[ "${push,,}" =~ ^n ]] && { note "Skipped push. Later: git push origin main --follow-tags"; return 0; }
  if git push origin main --follow-tags 2>&1 | sed -E 's#(ghp_|github_pat_|x-access-token:)[A-Za-z0-9_]+#\1***#g'; then
    ok "Pushed v$newver to origin"
  else fail "Push failed — retry: git push origin main --follow-tags"; return 1; fi
}

default_action() {
  if is_configured; then
    cmd_status; echo ""; note "Run 'yodacode help' for all commands."
  else
    note "Not set up yet — launching the guided installer…"; echo ""
    exec ./quickstart.sh
  fi
}

# ── dispatch ─────────────────────────────────────────────────────────────────
CMD="${1:-}"; [[ $# -gt 0 ]] && shift

# ── update banner ────────────────────────────────────────────────────────────
# npm-style update-notifier: THIS run prints from the cached result and, when
# the cache is stale (>24h), refreshes it in the background for the NEXT run —
# no command ever waits on the network. The cache lives in the agent-writable
# state dir, so parse it defensively (never source it into this root shell).
maybe_update_banner() {
  # Honour YODA_UPDATE_CHECK from the shell env OR .env (docs say .env works).
  local upd; upd="${YODA_UPDATE_CHECK:-$(env_get YODA_UPDATE_CHECK)}"
  [[ "${upd:-1}" == 0 ]] && return 0
  [[ "$CMD" == update || "$CMD" == release ]] && return 0
  [[ -t 2 ]] || return 0
  local cache="workspace/state/.cli-update-check" now checked latest cur newest
  now="$(date +%s)"
  checked="$(grep -m1 '^CHECKED_AT=' "$cache" 2>/dev/null | cut -d= -f2- | tr -dc '0-9')"
  latest="$(grep -m1 '^LATEST=' "$cache" 2>/dev/null | cut -d= -f2- | tr -dc 'v0-9.')"
  if (( now - ${checked:-0} > 86400 )); then
    # trap '' HUP: survive the terminal closing right after the command exits.
    # timeout + no-prompt: a stalled network or credential-less origin must
    # neither hang the detached child nor read from the tty. On failure,
    # advance CHECKED_AT (keeping the old LATEST) so offline hosts don't
    # respawn a checker on every command. Temp-file + mv keeps concurrent
    # refreshers from ever exposing a torn cache to a reader.
    ( trap '' HUP; { mkdir -p workspace/state 2>/dev/null
        t="$(GIT_TERMINAL_PROMPT=0 GIT_SSH_COMMAND='ssh -oBatchMode=yes' timeout 15 \
             git ls-remote --tags origin 'v*' 2>/dev/null </dev/null | sed 's#.*refs/tags/##' \
             | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | sort -V | tail -1)"
        tmp="$(mktemp workspace/state/.cli-update-check.XXXXXX 2>/dev/null)" || exit 0
        printf 'CHECKED_AT=%s\nLATEST=%s\n' "$(date +%s)" "${t:-$latest}" > "$tmp" && mv -f "$tmp" "$cache"
      } & ) >/dev/null 2>&1
  fi
  [[ "$latest" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]] || return 0
  cur="v$(grep -m1 '"version"' package.json 2>/dev/null | sed -E 's/.*"([0-9]+\.[0-9]+\.[0-9]+)".*/\1/')"
  [[ "$cur" == "$latest" || "$cur" == v ]] && return 0
  newest="$(printf '%s\n%s\n' "$cur" "$latest" | sort -V | tail -1)"
  [[ "$newest" == "$latest" ]] || return 0
  echo -e "  ${Y}▲ Update available: ${latest} (installed ${cur}) — run: yodacode update${X}" >&2
}
maybe_update_banner

# Self-heal: the first time this runs as ./yodacode and the launcher isn't
# installed yet, drop it onto PATH so every future call works without the ./.
# Keyed off the launcher files so it acts once, then stays silent — existing
# installs fix themselves on first use.
if [[ ! -e /usr/local/bin/yodacode && ! -e "$HOME/.local/bin/yodacode" ]]; then
  install_cli_wrapper
  if [[ "${YC_WRAPPER_PATH_ADDED:-0}" == 1 ]]; then
    note "Installed the 'yodacode' command — run 'source ~/.bashrc' (or open a new shell) to use it without ./"
  else
    note "Installed the 'yodacode' command — available in this and every shell."
  fi
fi

case "$CMD" in
  "")                   default_action ;;
  help|-h|--help)       cmd_help ;;
  doctor)               cmd_doctor ;;
  update)               cmd_update ;;
  start)                cmd_start ;;
  stop)                 cmd_stop ;;
  restart)              cmd_restart ;;
  logs)                 cmd_logs ;;
  shell)                cmd_shell ;;
  slack)                cmd_slack ;;
  googlechat)           cmd_googlechat ;;
  commitments)          cmd_commitments ;;
  persona)              cmd_persona ;;
  model)                cmd_model "$@" ;;
  tools)                cmd_tools "$@" ;;
  release)              cmd_release "$@" ;;
  addkey)               cmd_addkey "$@" ;;
  install-browsers)     cmd_install_browsers ;;
  connect)              cmd_connect "$@" ;;
  status)               cmd_status ;;
  version|-v|--version) cmd_version ;;
  setup)                exec ./quickstart.sh "$@" ;;
  *) fail "Unknown command: $CMD"; cmd_help; exit 1 ;;
esac
