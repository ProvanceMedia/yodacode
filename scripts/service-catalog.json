  "google": {
    "kind": "oauth-provider",
    "label": "Google",
    "aliases": [
      "google workspace",
      "gsuite",
      "google apis",
      "googleapis"
    ],
    "authUrl": "https://accounts.google.com/o/oauth2/v2/auth",
    "tokenUrl": "https://oauth2.googleapis.com/token",
    "clientIdKey": "GOOGLE_OAUTH_CLIENT_ID",
    "clientSecretKey": "GOOGLE_OAUTH_CLIENT_SECRET",
    "refreshTokenKey": "GOOGLE_REFRESH_TOKEN",
    "clientIdPattern": "\\.apps\\.googleusercontent\\.com$",
    "authParams": {
      "access_type": "offline",
      "prompt": "consent"
    },
    "identityScopes": [
      "openid",
      "email"
    ],
    "identityUrl": "https://www.googleapis.com/oauth2/v3/userinfo",
    "identityField": "email",
    "setupGuide": "docs/providers/google.md",
    "setupSteps": [
      {
        "text": "Create (or pick) a Google Cloud project",
        "url": "https://console.cloud.google.com/projectcreate"
      },
      {
        "text": "Enable the API for each service you're connecting (exact links printed below)"
      },
      {
        "text": "Configure the OAuth consent screen: user type External, add your own email",
        "url": "https://console.cloud.google.com/auth/branding"
      },
      {
        "text": "IMPORTANT \u2014 under Audience, click 'Publish app' so the status is 'In production'. Left in 'Testing', Google kills your sign-in every 7 days.",
        "url": "https://console.cloud.google.com/auth/audience"
      },
      {
        "text": "Create credentials: OAuth client ID, application type 'Desktop app'",
        "url": "https://console.cloud.google.com/auth/clients"
      }
    ],
    "services": {
      "gmail": {
        "label": "Gmail",
        "aliases": [
          "mail",
          "email",
          "google mail"
        ],
        "hosts": [
          "gmail.googleapis.com"
        ],
        "scopeTiers": [
          {
            "key": "read",
            "label": "Read-only \u2014 read and search mail",
            "scopes": [
              "https://www.googleapis.com/auth/gmail.readonly"
            ]
          },
          {
            "key": "modify",
            "label": "Read, send + organise mail (recommended)",
            "scopes": [
              "https://www.googleapis.com/auth/gmail.modify"
            ],
            "default": true
          }
        ],
        "testPath": "gmail/v1/users/me/profile",
        "enableApiUrl": "https://console.cloud.google.com/apis/library/gmail.googleapis.com",
        "note": "Gmail API (gmail/v1)"
      },
      "calendar": {
        "label": "Google Calendar",
        "aliases": [
          "gcal",
          "calendar"
        ],
        "hosts": [
          "www.googleapis.com"
        ],
        "scopeTiers": [
          {
            "key": "read",
            "label": "Read-only \u2014 view events",
            "scopes": [
              "https://www.googleapis.com/auth/calendar.readonly"
            ]
          },
          {
            "key": "full",
            "label": "View + create/edit events (recommended)",
            "scopes": [
              "https://www.googleapis.com/auth/calendar"
            ],
            "default": true
          }
        ],
        "testPath": "calendar/v3/users/me/calendarList?maxResults=1",
        "enableApiUrl": "https://console.cloud.google.com/apis/library/calendar-json.googleapis.com",
        "note": "Google Calendar API (calendar/v3)"
      },
      "drive": {
        "label": "Google Drive",
        "aliases": [
          "gdrive",
          "drive"
        ],
        "hosts": [
          "www.googleapis.com"
        ],
        "scopeTiers": [
          {
            "key": "read",
            "label": "Read-only \u2014 read and search files (recommended)",
            "scopes": [
              "https://www.googleapis.com/auth/drive.readonly"
            ],
            "default": true
          },
          {
            "key": "full",
            "label": "Full \u2014 create, edit + delete files",
            "scopes": [
              "https://www.googleapis.com/auth/drive"
            ]
          }
        ],
        "testPath": "drive/v3/about?fields=user",
        "enableApiUrl": "https://console.cloud.google.com/apis/library/drive.googleapis.com",
        "note": "Google Drive API (drive/v3)"
      },
      "contacts": {
        "label": "Google Contacts",
