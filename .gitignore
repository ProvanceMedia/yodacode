# Secrets
.env
workspace/.config/
workspace/.ssh/id_*

# Runtime state
workspace/state/
workspace/.memory-backups/
logs/
pollers/*.json

# Node
workspace/node_modules/
workspace/package-lock.json

# Cloned repos
workspace/github/

# User-specific data
workspace/exports/
workspace/legacy-memory/
workspace/legacy-crons/
workspace/legacy-scripts/
workspace/LEGACY_MEMORY.md

# Skill archive (user-specific history, recoverable via skill-review cron)
workspace/skills/archive/

# Auto-generated
workspace/CAPABILITIES.md
# Per-install sandbox config — rewritten by yoda.js on every startup
workspace/.claude/settings.json
workspace/.claude/settings.local.json

# Persona files — generated from templates/*.template on first install
# and edited per-deploy. Templates stay tracked; the rendered files are local.
workspace/CLAUDE.md
workspace/IDENTITY.md
workspace/MEMORY.md
workspace/USER.md

# User-created skills (skill-reflector writes here). INDEX.md is shipped.
workspace/skills/*.md
!workspace/skills/INDEX.md

# User-defined cron tasks. _template.yaml + examples/ stay tracked.
cron-tasks/*.yaml
!cron-tasks/_template.yaml

# Temp
*.png
*.jpg
workspace/.cache/
workspace/.local/
workspace/.pki/

# Per-install generated systemd units (use gen-units.sh to regenerate)
cron-tasks/systemd/yoda-cron@.service
cron-tasks/systemd/yoda-cron@*.timer

# Broker: personal credential configs (only *.example.json ship)
workspace/broker/auth-hosts.json
workspace/broker/services.policy.json
workspace/broker/secrets.json

# python bytecode cache
__pycache__/
*.pyc
